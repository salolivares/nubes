{
  "name": "nubes",
  "productName": "Nubes",
  "version": "1.0.0",
  "description": "A GUI for a highly opinionated photo publishing workflow",
  "keywords": [],
  "author": {
    "name": "Sal Olivares",
    "email": "git@salolivares.com"
  },
  "license": "MIT",
  "main": ".vite/build/index.js",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "test": "pnpm test:main && pnpm test:renderer",
    "test:main": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/vitest/vitest.mjs run --config vitest.config.main.ts",
    "test:renderer": "vitest run --config vitest.config.renderer.ts --passWithNoTests",
    "test:watch": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/vitest/vitest.mjs --config vitest.config.main.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
